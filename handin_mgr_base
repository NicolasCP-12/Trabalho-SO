acquire_lock() {
     while ! mkdir "$LOCKS/main.lock" 2>/dev/null; do
        sleep 1
    done
    :
}

release_lock() {
    rmdir "$LOCKS/main.lock" 2>/dev/null
    :
}





cmd_todo_add() {
    [ "${1-}" = "-h" ] && {
        print_todo_add_help
        return 0
    }
titulo=""
    prioridade=3
    data=""
    tags=""
    
    # Percorrer todos os argumentos
    while [ $# -gt 0 ]; do
        case "$1" in
            -p)
                prioridade="$2"
                shift 2
                ;;
            -d)
                data="$2"
                shift 2
                ;;
            -t)
                tags="$2"
                shift 2
                ;;
            *)
                
                titulo="$1"
                shift
                ;;
        esac
    done
    
    # Verificar se o tĂ­tulo foi informado
    if [ -z "$titulo" ]; then
        echo "Erro: TĂ­tulo Ă© obrigatĂłrio" >&2
        return 1
    fi
    
    # Verificar se prioridade Ă© vĂˇlida (1 a 5)
    if [ "$prioridade" -lt 1 ] || [ "$prioridade" -gt 5 ]; then
        echo "Erro: Prioridade deve ser entre 1 e 5" >&2
        return 1
    fi
    
    # Verificar data se foi informada
    if [ -n "$data" ]; then
        # Verifica se tem formato AAAA-MM-DD
        echo "$data" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'
        if [ $? -ne 0 ]; then
            echo "Erro: Data deve ser AAAA-MM-DD" >&2
            return 1
        fi
    fi
    
    
    acquire_lock
    
    # Calcular o prĂłximo ID
    if [ -s "$TODOS" ]; then
        ultimo_id=$(cut -d';' -f1 "$TODOS" | sort -n | tail -1)
        next_id=$((ultimo_id + 1))
    else
        next_id=1
    fi
    
    
    agora=$(date '+%Y-%m-%d %H:%M:%S')
    
    # Escrever no arquivo CSV
    echo "$next_id;OPEN;$prioridade;$data;$tags;$agora;;$titulo" >> "$TODOS"
    
    
    release_lock
    
    echo "Tarefa $next_id criada com sucesso"
}




cmd_todo_list() {
    [ "${1-}" = "-h" ] && {
        print_todo_list_help
        return 0
    }
mostrar_todas=""
    ordenar=""
    tag_filtro=""
    prio_min=0
    
    # Processar argumentos
    while [ $# -gt 0 ]; do
        case "$1" in
            -a)
                mostrar_todas="sim"
                shift
                ;;
            -s)
                ordenar="$2"
                shift 2
                ;;
            -t)
                tag_filtro="$2"
                shift 2
                ;;
            -p)
                prio_min="$2"
                shift 2
                ;;
            *)
                echo "Erro: OpĂ§ĂŁo desconhecida $1" >&2
                return 1
                ;;
        esac
    done
    
    # Verificar se arquivo existe
    if [ ! -f "$TODOS" ]; then
        echo "Nenhuma tarefa encontrada"
        return 0
    fi
    
    # Filtrar por status (OPEN ou todas)
    if [ -z "$mostrar_todas" ]; then
        # Mostrar sĂł OPEN
        grep -v '^[^;]*;DONE;' "$TODOS" > /tmp/tarefas_temp
    else
        # Mostrar todas
        cp "$TODOS" /tmp/tarefas_temp
    fi
    
    # Filtrar por prioridade mĂ­nima
    if [ "$prio_min" -gt 0 ]; then
        awk -F';' -v p="$prio_min" '$3 >= p' /tmp/tarefas_temp > /tmp/tarefas_temp2
        mv /tmp/tarefas_temp2 /tmp/tarefas_temp
    fi
    
    # Filtrar por tag
    if [ -n "$tag_filtro" ]; then
        grep ";$tag_filtro,\|,$tag_filtro\|;$tag_filtro$" /tmp/tarefas_temp > /tmp/tarefas_temp2
        mv /tmp/tarefas_temp2 /tmp/tarefas_temp
    fi
    
    # Ordenar
    case "$ordenar" in
        due)
            sort -t';' -k4,4 /tmp/tarefas_temp > /tmp/tarefas_temp2
            ;;
        prio)
            sort -t';' -k3,3 -r /tmp/tarefas_temp > /tmp/tarefas_temp2
            ;;
        created)
            sort -t';' -k6,6 /tmp/tarefas_temp > /tmp/tarefas_temp2
            ;;
        *)
            cat /tmp/tarefas_temp > /tmp/tarefas_temp2
            ;;
    esac
    
    # Mostrar resultado
    while IFS=';' read -r id status prio due tags created done title; do
        echo "[$id] (P$prio) $due $status tags:$tags - $title"
    done < /tmp/tarefas_temp2
    
    # Limpar arquivo temporĂˇrio
    rm -f /tmp/tarefas_temp /tmp/tarefas_temp2
}







cmd_todo_done() {
    [ "${1-}" = "-h" ] && {
        print_todo_done_help
        return 0
    }
id="$1"
    
    # Verificar se ID foi informado
    if [ -z "$id" ]; then
        echo "Erro: ID da tarefa Ă© obrigatĂłrio" >&2
        return 1
    fi
    
    # Verificar se arquivo existe
    if [ ! -f "$TODOS" ]; then
        echo "Erro: Nenhuma tarefa encontrada" >&2
        return 1
    fi
    
    # Pegar lock
    acquire_lock
    
    # Procurar a tarefa
    if grep -q "^$id;" "$TODOS"; then
        # Verificar se jĂˇ estĂˇ DONE
        if grep "^$id;DONE;" "$TODOS" > /dev/null; then
            echo "Tarefa $id jĂˇ estĂˇ concluĂ­da"
            release_lock
            return 0
        fi
        
        
        agora=$(date '+%Y-%m-%d %H:%M:%S')
        
        # Atualizar a linha
        awk -F';' -v id="$id" -v agora="$agora" '
            $1 == id {
                $2 = "DONE"
                $8 = agora
            }
            { print $1";"$2";"$3";"$4";"$5";"$6";"$7";"$8 }
        ' "$TODOS" > "$TODOS.tmp"
        
        mv "$TODOS.tmp" "$TODOS"
        echo "Tarefa $id marcada como concluĂ­da"
    else
        echo "Erro: Tarefa com ID $id nĂŁo encontrada" >&2
        release_lock
        return 1
    fi
    
    release_lock

    
}







